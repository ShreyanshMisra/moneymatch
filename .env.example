# MoneyMatch environment. Copy to `.env` and fill in.
# `apps/api/src/moneymatch_api/config.py` fails fast if a required var is missing.

# --- Runtime -----------------------------------------------------------------
# One of: local | dev | prod. Controls log formatting and debug behaviour.
ENV=local

# --- Database ----------------------------------------------------------------
# Async SQLAlchemy URL. Local Docker default shown; Supabase/Neon in dev/prod.
# NOTE: use the asyncpg driver (postgresql+asyncpg://...).
DATABASE_URL=postgresql+asyncpg://moneymatch:moneymatch@localhost:5432/moneymatch
# Host port the compose Postgres binds to. Override if 5432 is taken, and keep
# DATABASE_URL's port in sync.
DB_PORT=5432

# --- Auth (Supabase) ---------------------------------------------------------
# Supabase project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
# HS256 verification: the project's JWT secret (Supabase → Settings → API → JWT Secret).
# Leave blank to use asymmetric JWKS verification instead (SUPABASE_JWKS_URL).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Optional: JWKS endpoint for RS256/ES256 projects. Defaults to
# ${SUPABASE_URL}/auth/v1/.well-known/jwks.json when SUPABASE_JWT_SECRET is unset.
SUPABASE_JWKS_URL=
# Expected `aud` claim (Supabase issues "authenticated").
SUPABASE_JWT_AUDIENCE=authenticated

# --- Web origin / CORS -------------------------------------------------------
# Comma-separated list of allowed browser origins for the API.
WEB_ORIGIN=http://localhost:5173

# --- Host game APIs (used from Phase 2) --------------------------------------
FACEIT_API_KEY=

# --- Observability (optional) ------------------------------------------------
SENTRY_DSN=
# Release tag on Sentry events + PostHog captures (set to the git SHA in deploy).
RELEASE=
# Server-side product analytics (PostHog). Empty ⇒ server capture is a no-op.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# Warn when a host-API call exceeds this many milliseconds (ops signal).
SLOW_HOST_MS=2000

# --- Payments / KYC readiness (Phase 7) --------------------------------------
# The ONLY switches for real rails, and both are guarded in code: turning either
# on with no live provider compiled in raises at startup/first use. Leave false
# at MVP — real integration is a code change plus a flip, never a flip alone.
PAYMENTS_LIVE=false
KYC_LIVE=false

# --- Hardening (Phase 7) -----------------------------------------------------
# Max request body size in bytes (413 above this).
MAX_REQUEST_BYTES=65536
# Per-minute write/auth-sensitive request cap per client (429 above this).
RATE_LIMIT_WRITES_PER_MINUTE=60

# --- Web app (Vite; must be prefixed VITE_ to reach the browser) -------------
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase publishable/anon key (safe for the browser).
VITE_SUPABASE_ANON_KEY=your-supabase-publishable-key
# PostHog browser key + host (empty ⇒ client telemetry stays console-only).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Sentry browser DSN (empty ⇒ error tracking disabled in browser).
VITE_SENTRY_DSN=
