  },
  "components": {
    "schemas": {
      "CreateLinkRequest": {
        "properties": {
          "game": {
            "type": "string",
            "title": "Game"
          },
          "username": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1,
            "title": "Username"
          }
        },
        "type": "object",
        "required": [
          "game",
          "username"
        ],
        "title": "CreateLinkRequest",
        "description": "Intent to bind a host account. The server fetches + verifies everything;\nthe client only names the game and the handle to claim."
      },
      "DemoDepositRequest": {
        "properties": {
          "amount_preset_cents": {
            "type": "integer",
            "title": "Amount Preset Cents",
            "description": "One of the presets: [1000, 2500, 5000, 10000]"
          }
        },
        "type": "object",
        "required": [
          "amount_preset_cents"
        ],
        "title": "DemoDepositRequest",
        "description": "Server-defined preset only \u2014 never an arbitrary client amount."
      },
      "DemoWithdrawalRequest": {
        "properties": {
          "amount_cents": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Amount Cents",
            "description": "Cents; must be \u2264 available"
          }
        },
        "type": "object",
        "required": [
          "amount_cents"
        ],
        "title": "DemoWithdrawalRequest"
      },
      "FormatStat": {
        "properties": {
          "speed": {
            "type": "string",
            "enum": [
              "bullet",
              "blitz",
              "rapid",
              "classical"
            ],
            "title": "Speed"
          },
          "rating": {
            "type": "integer",
            "title": "Rating"
          },
          "games": {
            "type": "integer",
            "title": "Games"
          },
          "provisional": {
            "type": "boolean",
            "title": "Provisional",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "speed",
          "rating",
          "games"
        ],
        "title": "FormatStat",
        "description": "A single chess time-control's verified stats, sourced from the host."
      },
      "GameLink": {
        "properties": {
          "game": {
            "type": "string",
            "title": "Game"
          },
          "display_name": {
            "type": "string",
            "title": "Display Name"
          },
          "status": {
            "type": "string",
            "enum": [
              "LINKED",
              "BLOCKED",
              "UNLINKED"
            ],
            "title": "Status"
          },
          "host_username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Host Username"
          },
          "linked_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Linked At"
          },
          "profile": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ProfileSnapshot"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "game",
          "display_name",
          "status"
        ],
        "title": "GameLink",
        "description": "One game's row on Profile: linked snapshot or an empty/blocked slot.\n\n`status`: LINKED (active binding), BLOCKED (game flag off or binding frozen),\nUNLINKED (available to link)."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "env": {
            "type": "string",
            "title": "Env"
          },
          "version": {
            "type": "string",
            "title": "Version"
          },
          "games": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Games"
          },
          "flags": {
            "additionalProperties": {
              "type": "boolean"
            },
            "type": "object",
            "title": "Flags"
          }
        },
        "type": "object",
        "required": [
          "status",
          "env",
          "version",
          "games",
          "flags"
        ],
        "title": "HealthResponse"
      },
      "LedgerEntryResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "entry_type": {
            "type": "string",
            "title": "Entry Type"
          },
          "amount_cents": {
            "type": "integer",
            "title": "Amount Cents"
          },
          "escrow_delta_cents": {
            "type": "integer",
            "title": "Escrow Delta Cents"
          },
          "ref_type": {
            "type": "string",
            "title": "Ref Type"
          },
          "ref_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ref Id"
          },
          "balance_after_cents": {
            "type": "integer",
            "title": "Balance After Cents"
          },
          "memo": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Memo"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "entry_type",
          "amount_cents",
          "escrow_delta_cents",
          "ref_type",
          "ref_id",
          "balance_after_cents",
          "memo",
          "created_at"
        ],
        "title": "LedgerEntryResponse"
      },
      "LimitsResponse": {
        "properties": {
          "daily_loss_cap_cents": {
            "type": "integer",
            "title": "Daily Loss Cap Cents"
          },
          "daily_entry_cap_cents": {
            "type": "integer",
            "title": "Daily Entry Cap Cents"
          },
          "max_concurrent_contests": {
            "type": "integer",
            "title": "Max Concurrent Contests"
          },
          "pending_limits": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Pending Limits"
          },
          "pending_effective_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Pending Effective At"
          }
        },
        "type": "object",
        "required": [
          "daily_loss_cap_cents",
          "daily_entry_cap_cents",
          "max_concurrent_contests",
          "pending_limits",
          "pending_effective_at"
        ],
        "title": "LimitsResponse"
      },
      "LinksResponse": {
        "properties": {
          "games": {
            "items": {
              "$ref": "#/components/schemas/GameLink"
            },
            "type": "array",
            "title": "Games"
          }
        },
        "type": "object",
        "required": [
          "games"
        ],
        "title": "LinksResponse",
        "description": "Every registered game with the viewer's link state \u2014 drives Profile."
      },
      "MeResponse": {
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserResponse"
          },
          "needs_onboarding": {
            "type": "boolean",
            "title": "Needs Onboarding"
          },
          "limits": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/LimitsResponse"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "user",
          "needs_onboarding"
        ],
        "title": "MeResponse",
        "description": "`/me` payload: the user, a computed onboarding flag, and staking limits."
      },
      "ProfileSnapshot": {
        "properties": {
          "username": {
            "type": "string",
            "title": "Username"
          },
          "display_name": {
            "type": "string",
            "title": "Display Name"
          },
          "url": {
            "type": "string",
            "title": "Url"
          },
          "link_method": {
            "type": "string",
            "enum": [
              "username",
              "oauth"
            ],
            "title": "Link Method"
          },
          "game": {
            "type": "string",
            "title": "Game",
            "default": "chess.lichess"
          },
          "account_age_days": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Account Age Days"
          },
          "win_rate": {
            "type": "number",
            "title": "Win Rate"
          },
          "draw_rate": {
            "type": "number",
            "title": "Draw Rate",
            "default": 0.0
          },
          "total_games": {
            "type": "integer",
            "title": "Total Games"
          },
          "formats": {
            "items": {
              "$ref": "#/components/schemas/FormatStat"
            },
            "type": "array",
            "title": "Formats",
            "default": []
          },
          "primary_speed": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "bullet",
                  "blitz",
                  "rapid",
                  "classical"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Primary Speed"
          },
          "rating": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rating"
          },
          "rank_label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rank Label"
          },
          "kd": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Kd"
