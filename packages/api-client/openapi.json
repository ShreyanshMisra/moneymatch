    "/api/v1/links/{game}/profile": {
      "get": {
        "tags": [
          "links"
        ],
        "summary": "Refresh Link",
        "operationId": "refresh_link_api_v1_links__game__profile_get",
        "parameters": [
          {
            "name": "game",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Game"
            }
          },
          {
